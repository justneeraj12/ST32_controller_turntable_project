{
    "tasks": [
        {
            "label": "STM32: Verify Launch (auto-fix)",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/scripts/verify_stm32_debug_config.py",
                "--fix"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "STM32: Verify Launch (strict)",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/scripts/verify_stm32_debug_config.py",
                "--fix",
                "--strict"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc build active file",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}